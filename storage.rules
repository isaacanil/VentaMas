rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function currentUserDoc() {
      return firestore.get(
        /databases/(default)/documents/users/$(currentUid())
      );
    }

    function currentUserExists() {
      return isSignedIn()
        && firestore.exists(
          /databases/(default)/documents/users/$(currentUid())
        );
    }

    function currentUserRole() {
      return currentUserDoc().data.role != null
        ? currentUserDoc().data.role
        : (
          currentUserDoc().data.activeRole != null
            ? currentUserDoc().data.activeRole
            : (
              currentUserDoc().data.user.role != null
                ? currentUserDoc().data.user.role
                : currentUserDoc().data.user.activeRole
            )
        );
    }

    function isPlatformDev() {
      return currentUserExists()
        && (
          currentUserDoc().data.platformRoles.dev == true
          || currentUserDoc().data.user.platformRoles.dev == true
        );
    }

    function hasGlobalRole() {
      return currentUserExists() && (
        isPlatformDev()
        || currentUserRole() in ['dev']
      );
    }

    function memberDoc(businessId) {
      return firestore.get(
        /databases/(default)/documents/businesses/$(businessId)/members/$(currentUid())
      );
    }

    function hasBusinessAccess(businessId) {
      return isSignedIn()
        && (
          hasGlobalRole()
          || (
            firestore.exists(
              /databases/(default)/documents/businesses/$(businessId)/members/$(currentUid())
            )
            && !(memberDoc(businessId).data.status in ['inactive', 'suspended', 'revoked'])
          )
        );
    }

    function isImageUpload(maxSize) {
      return request.resource != null
        && request.resource.size <= maxSize
        && request.resource.contentType != null
        && request.resource.contentType.matches('image/.*');
    }

    function isBusinessUpload() {
      return request.resource != null
        && request.resource.size <= 26214400
        && request.resource.contentType != null
        && request.resource.contentType.matches(
          'image/.*|application/pdf|text/plain|text/csv|text/comma-separated-values|application/msword|application/vnd\\.ms-excel|application/vnd\\.openxmlformats-officedocument\\.wordprocessingml\\.document|application/vnd\\.openxmlformats-officedocument\\.spreadsheetml\\.sheet'
        );
    }

    function isReportUpload() {
      return request.resource != null
        && request.resource.size <= 52428800
        && request.resource.contentType != null
        && request.resource.contentType.matches(
          'application/pdf|text/plain|text/csv|application/vnd\\.ms-excel|application/vnd\\.openxmlformats-officedocument\\.spreadsheetml\\.sheet'
        );
    }

    // Imagen de login visible antes de autenticación.
    match /app-config/login-image/{fileName} {
      allow read: if true;
      allow create, update: if hasGlobalRole() && isImageUpload(5242880);
      allow delete: if hasGlobalRole();
    }

    // Reportes generados por funciones.
    match /reports/stock-digest/{businessId}/{allPaths=**} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update: if hasGlobalRole() && isReportUpload();
      allow delete: if hasGlobalRole();
    }

    // Namespace principal multi-tenant.
    match /businesses/{businessId}/{allPaths=**} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update: if hasBusinessAccess(businessId) && isBusinessUpload();
      allow delete: if hasBusinessAccess(businessId);
    }

    // Ruta legacy detectada en código; solo soporte dev/admin global.
    match /purchase/{allPaths=**} {
      allow read, write: if hasGlobalRole();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
