State synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  473 |     if (!isDeferredBillingEnabled) {\n  474 |       // eslint-disable-next-line react-hooks/set-state-in-effect -- Necessary to close the modal when deferred billing is disabled\n> 475 |       setIsOpen(false);\n      |       ^^^^^^^^^ Avoid calling setState() directly within an effect\n  476 |     }\n  477 |   }, [isDeferredBillingEnabled]);\n  478 |",["9672"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  29 |     dispatch(getTaxReceiptData(serializedTaxReceipt));\n  30 |     // eslint-disable-next-line react-hooks/set-state-in-effect -- Necessary to synchronize local state with Redux/Firebase derived data\n> 31 |     setTaxReceiptLocal(serializedTaxReceipt);\n     |     ^^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  32 |   }, [taxReceipt, dispatch]);\n  33 |\n  34 |   const handleSubmit = () => {",["9673"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  78 |     dispatch(getTaxReceiptData(serializedTaxReceipt));\n  79 |     // eslint-disable-next-line react-hooks/set-state-in-effect -- Necessary to synchronize local state with Redux/Firebase derived data\n> 80 |     setTaxReceiptLocal(serializedTaxReceipt);\n     |     ^^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  81 |   }, [taxReceipt, dispatch]);\n  82 |\n  83 |   const handleTaxReceiptEnabled = () => {",["9674"],"React Hook useEffect has missing dependencies: 'dispatch' and 'isOpen'. Either include them or remove the dependency array.",["9675"],["9676"],"Unexpected empty async arrow function.",["9677"],["9678"],["9679"],["9680"],["9681"],["9682"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  68 |     if (!value) {\n  69 |       // eslint-disable-next-line react-hooks/set-state-in-effect -- Necessary for synchronizing internal state (searchTerm, isOpen) with the 'value' prop\n> 70 |       setSearchTerm(''); // Si quieres reiniciar el término de búsqueda también\n     |       ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  71 |       setIsOpen(false);\n  72 |     }\n  73 |   }, [value]);",["9683"],{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9687","fix":"9688","desc":"9689"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9690","fix":"9691","desc":"9689"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9692","fix":"9693","desc":"9689"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9694","fix":"9695","desc":"9689"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9696","fix":"9697","desc":"9689"},{"kind":"9684","justification":"9685"},{"kind":"9684","justification":"9685"},{"kind":"9684","justification":"9685"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9698","fix":"9699","desc":"9689"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9700","fix":"9701","desc":"9689"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9702","fix":"9703","desc":"9689"},{"kind":"9684","justification":"9685"},{"desc":"9704","fix":"9705"},{"kind":"9684","justification":"9685"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9706","fix":"9707","desc":"9689"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9708","fix":"9709","desc":"9689"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9710","fix":"9711","desc":"9689"},{"kind":"9684","justification":"9685"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9712","fix":"9713","desc":"9689"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9714","fix":"9715","desc":"9689"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9716","fix":"9717","desc":"9689"},{"kind":"9684","justification":"9685"},{"messageId":"9686","data":"9718","fix":"9719","desc":"9720"},{"kind":"9684