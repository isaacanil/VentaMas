rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(currentUid());
    }

    function currentUserDoc() {
      return get(currentUserPath());
    }

    function currentUserExists() {
      return isSignedIn() && exists(currentUserPath());
    }

    function currentUserRole() {
      return currentUserDoc().data.role != null
        ? currentUserDoc().data.role
        : (
          currentUserDoc().data.activeRole != null
            ? currentUserDoc().data.activeRole
            : (
              currentUserDoc().data.user.role != null
                ? currentUserDoc().data.user.role
                : currentUserDoc().data.user.activeRole
            )
        );
    }

    function isPlatformDev() {
      return currentUserExists()
        && (
          currentUserDoc().data.platformRoles.dev == true
          || currentUserDoc().data.user.platformRoles.dev == true
        );
    }

    function hasGlobalRole() {
      return currentUserExists() && (
        isPlatformDev()
        || currentUserRole() in ['dev']
      );
    }

    function isSelf(userId) {
      return isSignedIn() && currentUid() == userId;
    }

    function memberPath(businessId) {
      return /databases/$(database)/documents/businesses/$(businessId)/members/$(currentUid());
    }

    function memberDoc(businessId) {
      return get(memberPath(businessId));
    }

    function hasCanonicalBusinessAccess(businessId) {
      return exists(memberPath(businessId))
        && !(memberDoc(businessId).data.status in ['inactive', 'suspended', 'revoked'])
        && memberDoc(businessId).data.active != false;
    }

    function hasLegacyBusinessAccess(businessId) {
      return currentUserExists()
        && (
          currentUserDoc().data.activeBusinessId == businessId
          || currentUserDoc().data.businessID == businessId
          || currentUserDoc().data.businessId == businessId
          || currentUserDoc().data.defaultBusinessId == businessId
          || currentUserDoc().data.lastSelectedBusinessId == businessId
        );
    }

    function hasBusinessAccess(businessId) {
      return isSignedIn()
        && (
          hasGlobalRole()
          || hasCanonicalBusinessAccess(businessId)
          || hasLegacyBusinessAccess(businessId)
        );
    }

    function currentBusinessRole(businessId) {
      return hasGlobalRole()
        ? 'dev'
        : (
          hasCanonicalBusinessAccess(businessId)
            ? memberDoc(businessId).data.role
            : currentUserRole()
        );
    }

    function hasBusinessRole(businessId, roles) {
      return hasBusinessAccess(businessId)
        && currentBusinessRole(businessId) in roles;
    }

    function hasAccountingReadAccess(businessId) {
      return hasBusinessRole(businessId, [
        'owner',
        'admin',
        'manager',
        'accountant',
        'controller',
        'auditor',
        'dev'
      ]);
    }

    function hasFinanceConfigAccess(businessId) {
      return hasBusinessRole(businessId, [
        'owner',
        'admin',
        'accountant',
        'controller',
        'dev'
      ]);
    }

    function hasTreasuryConfigAccess(businessId) {
      return hasBusinessRole(businessId, [
        'owner',
        'admin',
        'accountant',
        'controller',
        'dev'
      ]);
    }

    function documentPayload(data) {
      return data.keys().hasAny(['data']) && data.data is map ? data.data : data;
    }

    function documentStatus(data) {
      return documentPayload(data).status;
    }

    function isDraftFinancialDocument(data) {
      return documentStatus(data) in ['draft'];
    }

    function isLockedInvoiceStatus(data) {
      return documentStatus(data) in [
        'issued',
        'posted',
        'committed',
        'completed',
        'partial',
        'paid',
        'voided',
        'canceled',
        'cancelled',
        'reversed'
      ];
    }

    function hasPostedInvoiceFootprint(data) {
      return documentPayload(data).keys().hasAny([
        'NCF',
        'ncf',
        'comprobante',
        'numberID',
        'receivableState',
        'accumulatedPaid',
        'balanceDue',
        'paymentHistory',
        'cashCountId',
        'voidedAt',
        'cancel'
      ]) || data.keys().hasAny([
        'accountingEventId',
        'journalEntryId'
      ]);
    }

    function isLockedInvoiceDocument(data) {
      return isLockedInvoiceStatus(data) || hasPostedInvoiceFootprint(data);
    }

    function isSafeInvoiceDraftCreate(data) {
      return isDraftFinancialDocument(data)
        && !isLockedInvoiceDocument(data);
    }

    function isLockedPurchaseStatus(data) {
      return documentStatus(data) in [
        'completed',
        'delivered',
        'posted',
        'billed',
        'received',
        'paid',
        'voided',
        'canceled',
        'cancelled',
        'reversed'
      ];
    }

    function isMutablePurchaseSource(data) {
      return documentStatus(data) in [
        'draft',
        'pending',
        'requested',
        'pending_receipt',
        'processing',
        'partial_receipt'
      ];
    }

    function isDeletablePurchaseSource(data) {
      return documentStatus(data) in [
        'draft',
        'pending',
        'requested',
        'pending_receipt'
      ];
    }

    function hasPostedPurchaseFootprint(data) {
      return documentPayload(data).keys().hasAny([
        'vendorBillId',
        'accountsPayableId',
        'accountingEventId',
        'journalEntryId',
        'completedAt',
        'receivedAt',
        'billedAt',
        'canceledAt',
        'voidedAt'
      ]) || data.keys().hasAny([
        'vendorBillId',
        'accountsPayableId',
        'accountingEventId',
        'journalEntryId'
      ]);
    }

    function isLockedPurchaseDocument(data) {
      return isLockedPurchaseStatus(data) || hasPostedPurchaseFootprint(data);
    }

    function isSelfProfileCreate() {
      return !request.resource.data.keys().hasAny([
        'role',
        'activeRole',
        'platformRoles',
        'accessControl',
        'memberships',
        'availableBusinesses',
        'devBusinessSimulation'
      ]);
    }

    function isSelfProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'displayName',
        'name',
        'realName',
        'photoURL',
        'avatarUrl',
        'preferences',
        'settings',
        'lastSelectedBusinessId',
        'updatedAt'
      ]);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId) && isSelfProfileCreate();
      allow update: if isSelf(userId) && isSelfProfileUpdate();
      allow delete: if false;

      match /{document=**} {
        allow read, write: if isSelf(userId) || hasGlobalRole();
      }
    }

    match /app/{document=**} {
      allow read: if isSignedIn();
      allow write: if hasGlobalRole();
    }

    match /changelogs/{document=**} {
      allow read: if isSignedIn();
      allow write: if hasGlobalRole();
    }

    match /errors/{document=**} {
      allow create: if isSignedIn();
      allow read, update, delete: if hasGlobalRole();
    }

    match /sessionTokens/{document=**} {
      allow read, write: if hasGlobalRole();
    }

    match /rncData/{document=**} {
      allow read: if isSignedIn();
      allow write: if hasGlobalRole();
    }

    match /businesses/{businessId} {
      allow read, update: if hasBusinessAccess(businessId);
      allow create: if isSignedIn();
      allow delete: if false;
    }

    match /businesses/{businessId}/members/{memberId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    // Primer recorte P0-E:
    // estas colecciones ya deben mutarse desde backend/callables y no
    // deben seguir abiertas a escrituras arbitrarias desde cliente.
    match /businesses/{businessId}/journalEntries/{journalEntryId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
      match /{document=**} {
        allow read: if hasBusinessAccess(businessId);
        allow write: if false;
      }
    }

    match /businesses/{businessId}/accountingEvents/{eventId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
      match /{document=**} {
        allow read: if hasBusinessAccess(businessId);
        allow write: if false;
      }
    }

    match /businesses/{businessId}/accountingPeriodClosures/{periodKey} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
      match /{document=**} {
        allow read: if hasBusinessAccess(businessId);
        allow write: if false;
      }
    }

    match /businesses/{businessId}/settings/accounting {
      allow read: if hasAccountingReadAccess(businessId);
      allow create, update: if hasFinanceConfigAccess(businessId);
      allow delete: if false;

      match /history/{entryId} {
        allow read: if hasBusinessAccess(businessId);
        allow write: if false;
      }

      match /audit/{entryId} {
        allow read: if hasBusinessAccess(businessId);
        allow write: if false;
      }

      match /exchangeRateReference/{documentId} {
        allow read: if hasBusinessAccess(businessId);
        allow write: if false;

        match /{nestedDocument=**} {
          allow read: if hasBusinessAccess(businessId);
          allow write: if false;
        }
      }
    }

    match /businesses/{businessId}/exchangeRates/{exchangeRateId} {
      allow read: if hasAccountingReadAccess(businessId);
      allow create, update, delete: if false;
      match /{document=**} {
        allow read: if hasAccountingReadAccess(businessId);
        allow write: if false;
      }
    }

    match /businesses/{businessId}/bankAccounts/{bankAccountId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update: if hasTreasuryConfigAccess(businessId);
      allow delete: if false;

      match /history/{entryId} {
        allow read: if hasBusinessAccess(businessId);
        allow write: if false;
      }
    }

    match /businesses/{businessId}/chartOfAccounts/{chartOfAccountId} {
      allow read: if hasAccountingReadAccess(businessId);
      allow create, update, delete: if false;

      match /history/{entryId} {
        allow read: if hasBusinessAccess(businessId);
        allow write: if false;
      }
    }

    match /businesses/{businessId}/accountingPostingProfiles/{postingProfileId} {
      allow read: if hasAccountingReadAccess(businessId);
      allow create, update, delete: if false;

      match /history/{entryId} {
        allow read: if hasBusinessAccess(businessId);
        allow write: if false;
      }
    }

    match /businesses/{businessId}/invoices/{invoiceId} {
      allow read: if hasBusinessAccess(businessId);
      // Creación directa solo queda abierta para borradores sin huella
      // fiscal/contable. La emisión/finalización pasa por createInvoiceV2.
      allow create: if hasBusinessAccess(businessId)
        && isSafeInvoiceDraftCreate(request.resource.data);
      allow update: if hasBusinessAccess(businessId)
        && isDraftFinancialDocument(resource.data)
        && isDraftFinancialDocument(request.resource.data)
        && !isLockedInvoiceDocument(resource.data)
        && !isLockedInvoiceDocument(request.resource.data);
      allow delete: if hasBusinessAccess(businessId)
        && isDraftFinancialDocument(resource.data)
        && !isLockedInvoiceDocument(resource.data);

      match /{document=**} {
        allow read: if hasBusinessAccess(businessId);
        allow write: if false;
      }
    }

    match /businesses/{businessId}/invoicesV2/{invoiceId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;

      match /{document=**} {
        allow read: if hasBusinessAccess(businessId);
        allow write: if false;
      }
    }

    match /businesses/{businessId}/creditNotes/{creditNoteId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/creditNoteApplications/{applicationId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/accountsReceivable/{documentId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/accountsReceivablePayments/{documentId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/accountsReceivableInstallments/{documentId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/accountsReceivableInstallmentPayments/{documentId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/accountsPayable/{documentId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/accountsPayablePayments/{documentId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/payments/{documentId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/serviceCommissions/{documentId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/serviceCommissionCollaborators/{documentId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update: if hasBusinessAccess(businessId);
      allow delete: if false;
    }

    match /businesses/{businessId}/cashMovements/{movementId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/cashCounts/{cashCountId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/cashAccounts/{cashAccountId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update: if hasTreasuryConfigAccess(businessId);
      allow delete: if false;
    }

    match /businesses/{businessId}/treasuryAccounts/{accountId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update: if hasTreasuryConfigAccess(businessId);
      allow delete: if false;
    }

    match /businesses/{businessId}/internalTransfers/{transferId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/bankReconciliations/{reconciliationId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/bankStatementLines/{lineId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/ncfUsage/{usageId} {
      allow read: if hasAccountingReadAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/ncfLedger/{ledgerId} {
      allow read: if hasAccountingReadAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/taxReportRuns/{runId} {
      allow read: if hasAccountingReadAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/dgiiReports/{reportId} {
      allow read: if hasAccountingReadAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/taxReceipts/{taxReceiptId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update: if hasFinanceConfigAccess(businessId);
      allow delete: if false;
    }

    match /businesses/{businessId}/settings/{settingId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update: if hasBusinessAccess(businessId)
        && !(settingId in ['accounting']);
      allow delete: if false;
    }

    match /businesses/{businessId}/counters/{counterId} {
      allow read, create, update: if hasBusinessAccess(businessId);
      allow delete: if false;
    }

    match /businesses/{businessId}/products/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/productsImages/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/clients/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/providers/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/warehouses/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/warehouseStructure/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/rows/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/shelves/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/segments/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/batches/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/productsStock/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/movements/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/inventorySessions/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/backOrders/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/categories/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/orders/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/purchases/{purchaseId} {
      allow read: if hasBusinessAccess(businessId);
      allow create: if hasBusinessAccess(businessId)
        && isMutablePurchaseSource(request.resource.data)
        && !isLockedPurchaseDocument(request.resource.data);
      allow update: if hasBusinessAccess(businessId)
        && isMutablePurchaseSource(resource.data)
        && !isLockedPurchaseDocument(resource.data);
      allow delete: if hasBusinessAccess(businessId)
        && isDeletablePurchaseSource(resource.data)
        && !isLockedPurchaseDocument(resource.data);

      match /{document=**} {
        allow read: if hasBusinessAccess(businessId);
        allow write: if false;
      }
    }

    match /businesses/{businessId}/expenses/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/vendorBills/{vendorBillId} {
      allow read: if hasBusinessAccess(businessId);
      allow create, update, delete: if false;
    }

    match /businesses/{businessId}/doctors/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/userPermissions/{document=**} {
      allow read, write: if hasBusinessAccess(businessId);
    }

    match /businesses/{businessId}/{document=**} {
      allow read: if hasBusinessAccess(businessId);
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
