{
  "name": "ventamax",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vite build",
    "rollup": "npx rollup --config",
    "emulators": "firebase emulators:start --only functions,firestore",
    "preview": "vite preview",
    "lint": "npm run lint:web",
    "lint:report": "eslint . --ext js,jsx,ts,tsx | tee lint-report.md",
    "lint:web": "eslint . --ext js,jsx,ts,tsx",
    "lint:web:fix": "eslint . --ext js,jsx,ts,tsx --fix",
    "lint:fix": "npm run lint:web:fix",
    "lint:path": "eslint --ext js,jsx,ts,tsx",
    "lint:path:fix": "eslint --ext js,jsx,ts,tsx --fix",
    "lint:functions": "npm --prefix functions run lint",
    "lint:functions:fix": "npm --prefix functions run lint:fix",
    "lint:styles": "stylelint \"{src,functions}/**/*.{css,scss,js,jsx,ts,tsx}\"",
    "lint:styles:fix": "npm run lint:styles -- --fix",
    "lint:all": "npm run lint:web && npm run lint:functions && npm run lint:styles",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy:beta": "firebase hosting:channel:deploy beta",
    "deploy:prod": "firebase deploy --only hosting:prod",
    "deploy:staging": "firebase deploy --only hosting:staging",
    "deploy:vercel": "vercel --prod",
    "serve": "npx serve dist",
    "check-unused-exports": "pwsh -File .\\tools\\check-unused-exports.ps1",
    "check-unused-exports:saveCsv": "pwsh -File .\\tools\\check-unused-exports.ps1 -SaveCsv",
    "pending-updates": "bash ./tools/check_pending.sh",
    "storybook": "storybook dev -p 6006",
    "push:alt": "bash ./tools/push-to-alt-as-main.sh",
    "build-storybook": "storybook build"
  },
